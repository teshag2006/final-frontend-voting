{
    "name": "voting-system-backend",
    "version": "1.0.0",
    "description": "NestJS backend for secure blockchain-based voting system",
    "author": "VoteChain Team",
    "private": true,
    "license": "MIT",
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "start:cluster": "pm2 start ecosystem.config.js --env production",
        "start:cluster:dev": "pm2 start ecosystem.config.js --env development",
        "stop:cluster": "pm2 stop votechain-api",
        "restart:cluster": "pm2 restart votechain-api",
        "logs:cluster": "pm2 logs votechain-api",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "type-check": "tsc --noEmit -p tsconfig.json",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "typeorm": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
        "migration:generate": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d ./.typeormconfig.ts",
        "migration:run": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d ./.typeormconfig.ts",
        "migration:revert": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d ./.typeormconfig.ts",
        "migration:show": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:show -d ./.typeormconfig.ts",
        "seed": "ts-node -r tsconfig-paths/register seed.cli.ts",
        "seed:watch": "nodemon --exec ts-node -r tsconfig-paths/register seed.cli.ts"
    },
    "dependencies": {
        "@fastify/cors": "^10.0.1",
        "@fastify/helmet": "^11.1.1",
        "@fastify/static": "^7.0.1",
        "@nestjs-modules/ioredis": "^2.0.2",
        "@nestjs/axios": "^4.0.1",
        "@nestjs/bullmq": "^11.0.4",
        "@nestjs/common": "^10.2.10",
        "@nestjs/config": "^4.0.3",
        "@nestjs/core": "^10.2.10",
        "@nestjs/jwt": "^11.0.1",
        "@nestjs/passport": "^10.0.3",
        "@nestjs/platform-express": "^10.2.10",
        "@nestjs/platform-fastify": "^10.3.10",
        "@nestjs/platform-socket.io": "^10.2.10",
        "@nestjs/swagger": "^11.2.6",
        "@nestjs/terminus": "^11.1.0",
        "@nestjs/throttler": "^6.5.0",
        "@nestjs/typeorm": "^10.0.2",
        "@nestjs/websockets": "^10.2.10",
        "@scalar/api-reference": "^1.44.18",
        "argon2": "^0.44.0",
        "axios": "^1.13.5",
        "bullmq": "^5.69.3",
        "cache-manager": "^7.2.8",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "dotenv": "^16.3.1",
        "fastify": "^4.28.1",
        "helmet": "^7.2.0",
        "ioredis": "^5.9.3",
        "merkletreejs": "^0.3.11",
        "multer": "^1.4.5-lts.1",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "pg": "^8.11.3",
        "reflect-metadata": "^0.1.13",
        "rimraf": "^5.0.5",
        "rxjs": "^7.8.1",
        "socket.io": "^4.6.1",
        "swagger-ui-express": "^5.0.0",
        "typeorm": "^0.3.17",
        "web3": "^4.0.1",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.16",
        "@nestjs/schematics": "^10.0.3",
        "@nestjs/testing": "^10.2.10",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.10",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.10.4",
        "@types/passport-jwt": "^3.0.13",
        "@types/supertest": "^2.0.16",
        "@typescript-eslint/eslint-plugin": "^6.13.2",
        "@typescript-eslint/parser": "^6.13.2",
        "eslint": "^8.55.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.0.1",
        "jest": "^29.7.0",
        "nodemon": "^3.0.2",
        "prettier": "^3.1.0",
        "source-map-support": "^0.5.21",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.1",
        "ts-loader": "^9.5.1",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.3.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "moduleNameMapper": {
            "^@/(.*)$": "<rootDir>/$1"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
