# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=voting_system
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_SSL=false
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCK_MINUTES=15

# Application Configuration
NODE_ENV=development
APP_NAME=VoteChain
APP_PORT=3001
API_PREFIX=/api/v1
API_URL=http://localhost:3001

# Logging
LOG_LEVEL=debug

# Payment Providers

# Chapa (Ethiopian payment gateway)
CHAPA_SECRET_KEY=CHASECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHAPA_WEBHOOK_SECRET=your-chapa-webhook-secret
CHAPA_BASE_URL=https://api.chapa.co/v1

# SantimPay (Ethiopian payment gateway)
SANTIMPAY_BASE_URL=https://services.santimpay.com/api/v1/gateway
SANTIMPAY_MERCHANT_ID=your-santimpay-merchant-id
SANTIMPAY_GATEWAY_TOKEN=your-santimpay-gateway-token
SANTIMPAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
SANTIMPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Telebirr (Ethiopian mobile money)
# Testbed:  https://developerportal.ethiotelebirr.et:38443/apiaccess/payment/gateway
# Live:     https://telebirrappcube.ethiomobilemoney.et:38443/apiaccess/payment/gateway
TELEBIRR_BASE_URL=https://developerportal.ethiotelebirr.et:38443/apiaccess/payment/gateway
TELEBIRR_WEB_BASE_URL=https://developerportal.ethiotelebirr.et:38443/payment/web/paygate
TELEBIRR_X_APP_KEY=your-telebirr-x-app-key
TELEBIRR_APP_SECRET=your-telebirr-app-secret
TELEBIRR_APP_ID=your-telebirr-app-id
TELEBIRR_MERCH_CODE=your-telebirr-merch-code
TELEBIRR_WEBHOOK_SECRET=your-telebirr-webhook-secret
# Paste the full PEM key on one line (replace newlines with \n)
TELEBIRR_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
TELEBIRR_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# Legacy fields kept for reference (replaced by the above)
TELEBIRR_API_KEY=test_key
TELEBIRR_API_SECRET=test_secret

PAYPAL_CLIENT_ID=test_client_id
PAYPAL_CLIENT_SECRET=test_client_secret
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=test_webhook_id

# (see CHAPA_SECRET_KEY / CHAPA_WEBHOOK_SECRET above — these legacy keys kept for reference)
CHAPA_API_KEY=test_chapa_key

STRIPE_SECRET_KEY=test_stripe_key
STRIPE_WEBHOOK_SECRET=test_webhook_secret

CRYPTO_NETWORK=ethereum
CRYPTO_RPC_URL=http://localhost:8545
CRYPTO_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Blockchain (Optional)
BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_NETWORK=ethereum
BLOCKCHAIN_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
BLOCKCHAIN_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
BLOCKCHAIN_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Email Configuration (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@votechain.com
SMTP_PASSWORD=your_password
SMTP_FROM=noreply@votechain.com

# Notification Settings
NOTIFICATIONS_EMAIL_ENABLED=false
NOTIFICATIONS_SMS_ENABLED=false
# SMS Configuration (Twilio, etc.)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Fraud Alert Webhook (n8n Integration)
FRAUD_ALERT_WEBHOOK_ENABLED=false
N8N_WEBHOOK_URL=http://localhost:5678/webhook/fraud-alert

# OpenAI for Fraud Analysis
OPENAI_API_KEY=sk-your-openai-api-key
