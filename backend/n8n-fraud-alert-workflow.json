            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "WhatsApp (Critical)": {
      "main": [
        [
          {
            "node": "Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "staticData": null,
