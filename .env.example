AWS_REGION=us-east-1
AWS_S3_BUCKET=your-media-bucket-name
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000/api/v1
# Backward-compatible alias used by some legacy modules.
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
# Optional. If set, URLs are built as ${AWS_S3_PUBLIC_BASE_URL}/${key}
# AWS_S3_PUBLIC_BASE_URL=https://cdn.yourdomain.com

# Application base URL for auth email links.
APP_BASE_URL=http://localhost:3000

# AWS SES sender identity (must be verified in SES).
SES_FROM_EMAIL=no-reply@yourdomain.com
